  <!-- ============================================= -->
  <!-- BRUTE FORCE GLOBAL -->
  <!-- ============================================= -->
  <rule id="100999" level="12" frequency="5" timeframe="10">
    <if_matched_group>trapster</if_matched_group>
    <same_field>src_ip</same_field>
    <description>Multiple honeypot attacks from same IP</description>
